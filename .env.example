# Slack Incoming Webhook URL for #test-bb
# Paste the full URL from Slack → App → Incoming Webhooks
SLACK_WEBHOOK_URL=

# Optional but recommended: shared secret configured on the Bitbucket webhook
BITBUCKET_WEBHOOK_SECRET=choose-a-long-random-string

# Bot token with users:read.email — used for users.lookupByEmail
SLACK_BOT_TOKEN=

# Optional fallback when nickname matches email local-part: nickname@domain
COMPANY_EMAIL_DOMAIN=domain.com

# Map Bitbucket identity → Slack email when nickname ≠ email local-part.
# Prefer account_id (stable). JSON object with multiple users (single line for Netlify):
# {"xxxxxx:account-id":"user@domain.com","xxxxxx:account-id":"user_1@domain.com"}
BITBUCKET_TO_SLACK_EMAILS=

# Temporary: if set, these Slack member IDs are tagged (skips lookup).
# Comma-separated for multiple: xxxxxxxxxxx,xxxxxxxxxxx
# SLACK_MEMBER_ID=
